// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String       
  netIncome     Float        @default(0) 
  chorePoints   Int          @default(0) 
  
  items         BucketItem[] @relation("CreatedItems")
  approvedItems BucketItem[] @relation("ApprovedItems")
  expenses      Expense[]    @relation("UserExpenses")
  dateIdeas     DateIdea[]   @relation("CreatedDates")
  gifts         GiftIdea[]   @relation("UserGifts")
  checkIns      CheckInAnswer[] @relation("UserCheckIns")
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model BucketItem {
  id          String   @id @default(cuid())
  title       String
  price       Float    @default(0)
  savedAmount Float    @default(0)
  isSurprise  Boolean  @default(false)
  isCompleted Boolean  @default(false)
  creatorId   String
  creator     User     @relation("CreatedItems", fields: [creatorId], references: [id])
  approverId  String?
  approver    User?    @relation("ApprovedItems", fields: [approverId], references: [id])
  isPurchased Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinancialObligation {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  type        String   
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  title       String   
  amount      Float
  date        DateTime @default(now())
  userId      String
  user        User     @relation("UserExpenses", fields: [userId], references: [id])
}

model ShoppingItem {
  id        String   @id @default(cuid())
  title     String
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Chore {
  id          String   @id @default(cuid())
  title       String
  points      Int      @default(10)
  lastDoneBy  String?
  lastDoneAt  DateTime?
  createdAt   DateTime @default(now())
}

model DateIdea {
  id          String   @id @default(cuid())
  title       String
  isUsed      Boolean  @default(false)
  creatorId   String
  creator     User     @relation("CreatedDates", fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
}

model MealPlan {
  id          String   @id @default(cuid())
  dayOfWeek   Int      
  mealType    String   
  recipe      String
  ingredients String[] 
  recipeNotes String?  // NEU: Für Links oder Kochanleitungen
  createdAt   DateTime @default(now())
}

model VaultItem {
  id          String   @id @default(cuid())
  title       String
  url         String?  // Jetzt optional
  fileData    String?  // NEU: Base64 Datei-Inhalt
  fileType    String?  // NEU: z.B. application/pdf
  addedBy     String
  createdAt   DateTime @default(now())
}

model WikiEntry {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("Allgemein")
  addedBy   String
  createdAt DateTime @default(now())
}

model Subscription {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  cycle       String   @default("MONTHLY") 
  createdAt   DateTime @default(now())
}

model Trip {
  id          String   @id @default(cuid())
  title       String
  destination String
  date        DateTime
  savedAmount Float    @default(0) // NEU: Angespartes Geld
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model TravelPoint {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("WANT_TO_GO") 
  createdAt DateTime @default(now())
}

model GiftIdea {
  id          String   @id @default(cuid())
  title       String
  price       Float?
  url         String?
  isPurchased Boolean  @default(false)
  userId      String
  user        User     @relation("UserGifts", fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  type        String   @default("EVENT") 
  creatorId   String
  createdAt   DateTime @default(now())
}

model CheckInAnswer {
  id          String   @id @default(cuid())
  weekYear    String   
  highlight   String
  stress      String
  nextWeek    String
  userId      String
  user        User     @relation("UserCheckIns", fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([weekYear, userId]) 
}

model SmartDevice {
  id          String   @id @default(cuid())
  name        String
  type        String   
  externalId  String?  
  modelCode   String?  
  isActive    Boolean  @default(false)
  value       String?
  room        String   @default("Wohnzimmer")
  addedBy     String
  createdAt   DateTime @default(now())
}

model StickyNote {
  id        String   @id @default(cuid())
  text      String?
  imageUrl  String?
  author    String
  createdAt DateTime @default(now())
}

model PetFood {
  id        String   @id @default(cuid())
  cans      Int      @default(10)
  updatedAt DateTime @updatedAt
}

model LitterBoxLog {
  id        String   @id @default(cuid())
  boxId     Int      
  cleanedBy String
  createdAt DateTime @default(now())
}

model PetHealthEvent {
  id        String   @id @default(cuid())
  title     String   
  dueDate   DateTime
}

model PantryItem {
  id        String   @id @default(cuid())
  name      String
  count     Int      @default(0)
  minCount  Int      @default(1)
  updatedAt DateTime @updatedAt
}

model EnergyReading {
  id        String   @id @default(cuid())
  type      String   
  value     Float
  date      DateTime @default(now())
}

model EnergySettings {
  id                String   @id @default(cuid())
  kwhPrice          Float    @default(0.35)
  monthlyPrepayment Float    @default(80.0)
  updatedAt         DateTime @updatedAt
}

model SharedContact {
  id        String   @id @default(cuid())
  name      String
  role      String   
  phone     String?
  email     String?
}